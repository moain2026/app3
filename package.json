{
  "name": "abbasi-tahseel",
  "version": "1.0.0",
  "private": true,
  "description": "العباسي تحصيل — Field collection app for Al-Abbasi Commercial Electricity Generation Company",
  "author": "Al-Abbasi Commercial Electricity Generation Company",
  "license": "UNLICENSED",
  "scripts": {
    "android": "react-native run-android",
    "start": "react-native start",
    "start:reset": "react-native start --reset-cache",
    "build:android:debug": "cd android && ./gradlew assembleDebug",
    "build:android:release": "cd android && ./gradlew assembleRelease",
    "clean:android": "cd android && ./gradlew clean",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run test",
    "assets": "npx react-native-asset",
    "deps:graph": "madge --circular --extensions ts,tsx src/",
    "prepare": "husky install"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "~4.6.4",
    "@hookform/resolvers": "^3.9.0",
    "@nozbe/watermelondb": "~0.27.1",
    "@nozbe/with-observables": "~1.6.0",
    "@react-native-async-storage/async-storage": "~1.23.0",
    "@react-native-community/netinfo": "~11.3.2",
    "@react-navigation/bottom-tabs": "~6.6.1",
    "@react-navigation/drawer": "~6.7.2",
    "@react-navigation/native": "~6.1.18",
    "@react-navigation/native-stack": "~6.11.0",
    "@shopify/flash-list": "~1.7.1",
    "axios": "^1.7.4",
    "axios-retry": "^4.5.0",
    "buffer": "~6.0.3",
    "date-fns": "^3.6.0",
    "date-fns-jalali": "^3.6.0-0",
    "i18next": "^23.14.0",
    "react": "18.2.0",
    "react-hook-form": "^7.52.2",
    "react-i18next": "^15.0.1",
    "react-native": "0.74.5",
    "react-native-background-fetch": "4.2.5",
    "react-native-bluetooth-classic": "^1.73.0-rc.12",
    "react-native-config": "~1.5.3",
    "react-native-device-info": "~11.1.0",
    "react-native-gesture-handler": "~2.18.1",
    "react-native-get-random-values": "~1.11.0",
    "react-native-keychain": "~8.2.0",
    "react-native-mmkv": "~2.12.2",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "~4.11.0",
    "react-native-screens": "~3.34.0",
    "react-native-share": "~10.2.1",
    "react-native-svg": "~15.6.0",
    "react-native-vector-icons": "~10.1.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/plugin-proposal-decorators": "^7.24.7",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native/babel-preset": "0.74.85",
    "@react-native/eslint-config": "0.74.85",
    "@react-native/metro-config": "0.74.85",
    "@react-native/typescript-config": "0.74.85",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.6",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/uuid": "^10.0.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-native": "^4.1.0",
    "husky": "^9.1.4",
    "jest": "^29.6.3",
    "lint-staged": "^15.2.9",
    "madge": "^8.0.0",
    "prettier": "3.3.3",
    "react-test-renderer": "18.2.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings 0",
      "prettier --write"
    ],
    "*.{js,jsx,json,md}": [
      "prettier --write"
    ]
  },
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|@react-navigation|@shopify|@nozbe|@gorhom)/)"
    ],
    "setupFiles": [
      "./jest.setup.ts"
    ]
  }
}
